#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
target_dir="${CARGO_TARGET_DIR:-"$repo_root/target"}"
build_flag="--release"
target_profile="release"
open_result=false
local_install=false
can_notarize=false

help_info() {
	echo "
Usage: ${0##*/} [options] [architecture=host]
Build the application bundle and DMG for macOS.

Options:
  -d    Compile in debug mode and skip DMG creation.
  -o    Open the resulting DMG directory or launch the app in debug mode.
  -i    Install the resulting DMG into /Applications.
  -h    Display this help and exit.
"
}

while getopts 'doih' flag; do
	case "${flag}" in
		d)
			export CARGO_INCREMENTAL=true
			build_flag=""
			target_profile="debug"
			;;
		o) open_result=true ;;
		i) local_install=true ;;
		h)
			help_info
			exit 0
			;;
	esac
done
shift $((OPTIND - 1))

if [[ "$(uname -s)" != "Darwin" ]]; then
	echo "script/bundle-mac must be run on macOS." >&2
	exit 1
fi

version_info="$(rustc --version --verbose)"
host_line="$(echo "$version_info" | grep host)"
target_triple="${host_line#*: }"
if [[ $# -gt 0 && -n "$1" ]]; then
	target_triple="$1"
fi

case "$target_triple" in
	x86_64-apple-darwin) arch_suffix="x86_64" ;;
	aarch64-apple-darwin) arch_suffix="aarch64" ;;
	*)
		echo "Unsupported macOS architecture: $target_triple" >&2
		exit 1
		;;
esac

(cd "$repo_root" && cargo xtask setup-gstreamer --platform darwin --arch "$arch_suffix" --mode bundle --install)
gstreamer_env="$(cd "$repo_root" && cargo xtask setup-gstreamer --platform darwin --arch "$arch_suffix" --mode bundle --print-env)"
eval "$gstreamer_env"

(cd "$repo_root" && cargo xtask setup-ffmpeg --platform darwin --arch "$arch_suffix")
rustup target add "$target_triple"

(
	cd "$repo_root/frame-app"
	cargo bundle ${build_flag} --format osx --target "$target_triple"
)
cargo build --manifest-path "$repo_root/frame-updater/Cargo.toml" ${build_flag} --target "$target_triple" --bin frame-update-helper

app_bundle=""
for candidate in \
	"$target_dir/$target_triple/$target_profile/bundle/osx/Frame GPUI Lab.app" \
	"$target_dir/$target_profile/bundle/osx/Frame GPUI Lab.app" \
	"$target_dir/$target_triple/$target_profile/bundle/osx/Frame.app" \
	"$target_dir/$target_profile/bundle/osx/Frame.app"; do
	if [[ -d "$candidate" ]]; then
		app_bundle="$candidate"
		break
	fi
done

if [[ -z "$app_bundle" ]]; then
	echo "Missing application bundle. Checked:" >&2
	echo "  $target_dir/$target_triple/$target_profile/bundle/osx/Frame GPUI Lab.app" >&2
	echo "  $target_dir/$target_profile/bundle/osx/Frame GPUI Lab.app" >&2
	echo "  $target_dir/$target_triple/$target_profile/bundle/osx/Frame.app" >&2
	echo "  $target_dir/$target_profile/bundle/osx/Frame.app" >&2
	exit 1
fi

helper_binary="$target_dir/$target_triple/$target_profile/frame-update-helper"
if [[ ! -x "$helper_binary" ]]; then
	echo "Missing update helper binary: $helper_binary" >&2
	exit 1
fi
cp "$helper_binary" "$app_bundle/Contents/MacOS/frame-update-helper"

(cd "$repo_root" && cargo xtask stage-gstreamer --app "$app_bundle")

resource_dir="$app_bundle/Contents/Resources/resources/binaries"
for binary in "ffmpeg-$target_triple" "ffprobe-$target_triple"; do
	if [[ ! -x "$resource_dir/$binary" ]]; then
		echo "Missing bundled runtime binary: $resource_dir/$binary" >&2
		exit 1
	fi
done

if [[ -n "${MACOS_SIGNING_IDENTITY:-}" ]]; then
	echo "Code signing application bundle"
	codesign --force --deep --timestamp --options runtime --sign "$MACOS_SIGNING_IDENTITY" "$app_bundle" -v
fi

if [[ "$target_profile" = "debug" ]]; then
	echo "Debug build detected - skipping DMG creation."
	if [[ "$open_result" = true ]]; then
		open "$app_bundle"
	fi
	echo "Created application bundle: $app_bundle"
	exit 0
fi

if [[ -n "${APPLE_NOTARIZATION_KEY:-}" && -n "${APPLE_NOTARIZATION_KEY_ID:-}" && -n "${APPLE_NOTARIZATION_ISSUER_ID:-}" && -n "${MACOS_SIGNING_IDENTITY:-}" ]]; then
	can_notarize=true
fi

dmg_target_directory="$target_dir/$target_triple/$target_profile"
dmg_source_directory="$dmg_target_directory/dmg"
dmg_file_path="$dmg_target_directory/FrameGpuiLab-$arch_suffix.dmg"
app_zip_file_path="$dmg_target_directory/FrameGpuiLab-$arch_suffix.app.zip"

create_app_zip() {
	rm -f "$app_zip_file_path"
	ditto -c -k --sequesterRsrc --keepParent "$app_bundle" "$app_zip_file_path"
}

create_app_zip

if [[ "$can_notarize" = true ]]; then
	xcode_bin_dir_path="$(xcode-select -p)/usr/bin"
	notarization_key_file="$(mktemp)"
	echo "$APPLE_NOTARIZATION_KEY" > "$notarization_key_file"

	echo "Notarizing app zip with Apple"
	"$xcode_bin_dir_path/notarytool" submit --wait --key "$notarization_key_file" --key-id "$APPLE_NOTARIZATION_KEY_ID" --issuer "$APPLE_NOTARIZATION_ISSUER_ID" "$app_zip_file_path"
	"$xcode_bin_dir_path/stapler" staple "$app_bundle"
	create_app_zip
fi

rm -rf "$dmg_source_directory"
mkdir -p "$dmg_source_directory"
cp -R "$app_bundle" "$dmg_source_directory/Frame GPUI Lab.app"

echo "Adding symlink to /Applications to $dmg_source_directory"
ln -s /Applications "$dmg_source_directory/Applications"

echo "Creating final DMG at $dmg_file_path using $dmg_source_directory"
rm -f "$dmg_file_path"
hdiutil create -volname "Frame GPUI Lab" -srcfolder "$dmg_source_directory" -ov -format UDZO "$dmg_file_path"

rm "$dmg_source_directory/Applications"

if [[ "$can_notarize" = true ]]; then
	echo "Code signing DMG"
	codesign --force --timestamp --options runtime --sign "$MACOS_SIGNING_IDENTITY" "$dmg_file_path" -v
	echo "Notarizing DMG with Apple"
	"$xcode_bin_dir_path/notarytool" submit --wait --key "$notarization_key_file" --key-id "$APPLE_NOTARIZATION_KEY_ID" --issuer "$APPLE_NOTARIZATION_ISSUER_ID" "$dmg_file_path"
	rm "$notarization_key_file"
	"$xcode_bin_dir_path/stapler" staple "$dmg_file_path"
fi

if [[ "$local_install" = true ]]; then
	open "$dmg_file_path"
fi

if [[ "$open_result" = true ]]; then
	open "$dmg_target_directory"
fi

echo "Created $dmg_file_path"
echo "Created $app_zip_file_path"

#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ "$(uname -s)" != "Darwin" ]]; then
	echo "scripts/bundle-macos must be run on macOS." >&2
	exit 1
fi

case "$(uname -m)" in
	arm64 | aarch64)
		runtime_triple="aarch64-apple-darwin"
		;;
	x86_64)
		runtime_triple="x86_64-apple-darwin"
		;;
	*)
		echo "Unsupported macOS architecture: $(uname -m)." >&2
		exit 1
		;;
esac

node "$repo_root/scripts/setup-ffmpeg.cjs"

(
	cd "$repo_root/frame-app"
	cargo bundle --release --format osx
)

app_bundle="$repo_root/frame-app/target/release/bundle/osx/Frame.app"
resource_dir="$app_bundle/Contents/Resources/resources/binaries"
for binary in "ffmpeg-$runtime_triple" "ffprobe-$runtime_triple"; do
	if [[ ! -x "$resource_dir/$binary" ]]; then
		echo "Missing bundled runtime binary: $resource_dir/$binary" >&2
		exit 1
	fi
done

echo "Created $app_bundle"
